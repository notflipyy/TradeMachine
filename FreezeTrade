-- Función para animación de entrada circular
local function playEntranceAnimation()
    local entranceTime = 0.5
    
    -- Animación de fade in
    local fadeInTween = TweenService:Create(MainFrame, TweenInfo.new(entranceTime), {
        BackgroundTransparency = 0
    })
    
    -- Animación de borde
    local borderTween = TweenService:Create(Border, TweenInfo.new(entranceTime), {
        Transparency = 0
    })
    
    -- Animación de escala circular (efecto pop desde el centro)
    MainFrame.Size = UDim2.new(0, 10, 0, 10)
    MainFrame.Position = UDim2.new(0.5, -5, 0.5, -5)
    
    local scaleTween = TweenService:Create(MainFrame, TweenInfo.new(entranceTime, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 240, 0, 240),
        Position = UDim2.new(0.5, -120, 0.5, -120)
    })
    
    -- Ejecutar animaciones
    fadeInTween:Play()
    borderTween:Play()
    scaleTween:Play()
    
    -- Efecto de brillo en título (pulsante)
    task.spawn(function()
        for i = 1, 3 do
            local glowTween1 = TweenService:Create(Title, TweenInfo.new(0.3), {
                TextStrokeTransparency = 0.2
            })
            local glowTween2 = TweenService:Create(Title, TweenInfo.new(0.3), {
                TextStrokeTransparency = 0.5
            })
            glowTween1:Play()
            task.wait(0.3)
            glowTween2:Play()
            task.wait(0.3)
        end
    end)
    
    -- Animación de rotación sutil para efecto dinámico
    task.spawn(function()
        local rotationTween = TweenService:Create(MainFrame, TweenInfo.new(entranceTime * 1.5), {
            Rotation = 5
        })
        local rotationBackTween = TweenService:Create(MainFrame, TweenInfo.new(entranceTime * 1.5), {
            Rotation = -5
        })
        local rotationResetTween = TweenService:Create(MainFrame, TweenInfo.new(entranceTime * 1.5), {
            Rotation = 0
        })
        
        rotationTween:Play()
        task.wait(entranceTime * 1.5)
        rotationBackTween:Play()
        task.wait(entranceTime * 1.5)
        rotationResetTween:Play()
    end)
end

