-- Sistema de arrastre individual (compatible con PC y celular, sin afectar cámara)
local function setupDragging()
    local function updateDrag(input)
        if dragging then
            local delta = input.Position - dragStartPos
            MainFrame.Position = UDim2.new(
                guiStartPos.X.Scale,
                guiStartPos.X.Offset + delta.X,
                guiStartPos.Y.Scale,
                guiStartPos.Y.Offset + delta.Y
            )
            MainFrame.Rotation = delta.X * 0.1
        end
    end

    -- Iniciar arrastre (PC con mouse o celular con touch)
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStartPos = input.Position
            guiStartPos = MainFrame.Position

            -- Evitar que el input afecte la cámara
            input.UserInputState = Enum.UserInputState.Begin

            TweenService:Create(MainFrame, TweenInfo.new(0.1), {
                BackgroundTransparency = 0.1
            }):Play()

            local connection
            connection = RunService.RenderStepped:Connect(function()
                if dragging then
                    updateDrag(input)
                else
                    connection:Disconnect()
                end
            end)
        end
    end)

    -- Finalizar arrastre (PC y celular)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 
        or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                TweenService:Create(MainFrame, TweenInfo.new(0.1), {
                    BackgroundTransparency = 0
                }):Play()

                local currentPos = MainFrame.Position
                TweenService:Create(MainFrame, TweenInfo.new(0.15), {
                    Position = UDim2.new(
                        currentPos.X.Scale,
                        currentPos.X.Offset + math.random(-8, 8),
                        currentPos.Y.Scale,
                        currentPos.Y.Offset + math.random(-8, 8)
                    ),
                    Rotation = math.random(-3, 3)
                }):Play()

                task.wait(0.15)

                TweenService:Create(MainFrame, TweenInfo.new(0.15), {
                    Position = currentPos,
                    Rotation = 0
                }):Play()
            end
        end
    end)
end

